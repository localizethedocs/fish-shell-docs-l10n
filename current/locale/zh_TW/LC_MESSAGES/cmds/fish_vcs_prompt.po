#: ../../../cmds/fish_vcs_prompt.rst:2
msgid ""
"fish_vcs_prompt - output version control system information for use in a "
"prompt"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:7
msgid "fish_vcs_prompt"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:13
msgid ""
"function fish_prompt\n"
"     printf '%s' $PWD (fish_vcs_prompt) ' $ '\n"
"end"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:18
msgid "Description"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:20
msgid ""
"The ``fish_vcs_prompt`` function displays information about the current "
"version control system (VCS) repository, if any."
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:22
msgid ""
"It calls out to VCS-specific functions. The currently supported systems are:"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:24
msgid ":doc:`fish_git_prompt <fish_git_prompt>`"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:25
msgid ":doc:`fish_hg_prompt <fish_hg_prompt>`"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:26
msgid ":doc:`fish_svn_prompt <fish_svn_prompt>`"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:28
msgid "If a VCS isn't installed, the respective function does nothing."
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:30
msgid ""
"The Subversion prompt is disabled by default, because it's slow on large "
"repositories. To enable it, modify ``fish_vcs_prompt`` to uncomment it. See :"
"doc:`funced <funced>`."
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:32
msgid ""
"For more information, see the documentation for each of the functions above."
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:35
msgid "Example"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:37
msgid "A simple prompt that displays all known VCS info::"
msgstr ""

#: ../../../cmds/fish_vcs_prompt.rst:39
msgid ""
"function fish_prompt\n"
"    ...\n"
"    set -g __fish_git_prompt_showupstream auto\n"
"    printf '%s %s$' $PWD (fish_vcs_prompt)\n"
"end"
msgstr ""
