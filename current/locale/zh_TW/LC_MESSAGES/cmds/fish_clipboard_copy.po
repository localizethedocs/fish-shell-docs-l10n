msgid "fish_clipboard_copy - copy text to the system's clipboard"
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:7
msgid ""
"fish_clipboard_copy\n"
"\n"
"foo | fish_clipboard_copy"
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:16
msgid ""
"The ``fish_clipboard_copy`` function copies text to the system clipboard."
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:18
msgid ""
"If stdin is not a terminal (see :doc:`isatty <isatty>`), it will read all "
"input from there and copy it. If it is, it will use the current commandline, "
"or the current selection if there is one."
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:20
msgid "It is bound to :kbd:`ctrl-x` by default."
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:22
msgid ""
"``fish_clipboard_copy`` works by calling a system-specific backend. If it "
"doesn't appear to work you may need to install yours."
msgstr ""

