msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:28
msgid "``xsel`` and ``xclip`` for X11"
msgstr ""

#: ../../../cmds/fish_clipboard_copy.rst:29
msgid "``clip.exe`` on Windows."
msgstr ""

