#: ../../../cmds/if.rst:2
msgid "if - conditionally execute a command"
msgstr ""

#: ../../../cmds/if.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/if.rst:7
msgid ""
"if CONDITION; COMMANDS_TRUE ...;\n"
"[else if CONDITION2; COMMANDS_TRUE2 ...;]\n"
"[else; COMMANDS_FALSE ...;]\n"
"end"
msgstr ""

#: ../../../cmds/if.rst:15
msgid "Description"
msgstr "描述"

#: ../../../cmds/if.rst:17
msgid ""
"``if`` will execute the command ``CONDITION``. If the condition's exit "
"status is 0, the commands ``COMMANDS_TRUE`` will execute.  If the exit "
"status is not 0 and :doc:`else <else>` is given, ``COMMANDS_FALSE`` will be "
"executed."
msgstr ""

#: ../../../cmds/if.rst:19
msgid ""
"You can use :doc:`not <not>`, :doc:`and <and>` or :doc:`or <or>` in the "
"condition. See the second example below."
msgstr ""

#: ../../../cmds/if.rst:21
msgid ""
"The exit status of the last foreground command to exit can always be "
"accessed using the :ref:`$status <variables-status>` variable."
msgstr ""

#: ../../../cmds/if.rst:23
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/if.rst:26
msgid "Example"
msgstr "範例"

#: ../../../cmds/if.rst:28
msgid ""
"The following code will print ``foo.txt exists`` if the file foo.txt exists "
"and is a regular file, otherwise it will print ``bar.txt exists`` if the "
"file bar.txt exists and is a regular file, otherwise it will print ``foo.txt "
"and bar.txt do not exist``."
msgstr ""

#: ../../../cmds/if.rst:32
msgid ""
"if test -f foo.txt\n"
"    echo foo.txt exists\n"
"else if test -f bar.txt\n"
"    echo bar.txt exists\n"
"else\n"
"    echo foo.txt and bar.txt do not exist\n"
"end"
msgstr ""

#: ../../../cmds/if.rst:41
msgid ""
"The following code will print \"foo.txt exists and is readable\" if foo.txt "
"is a regular file and readable"
msgstr ""

#: ../../../cmds/if.rst:45
msgid ""
"if test -f foo.txt\n"
"   and test -r foo.txt\n"
"   echo \"foo.txt exists and is readable\"\n"
"end"
msgstr ""

#: ../../../cmds/if.rst:52
msgid "See also"
msgstr "另請參見"

#: ../../../cmds/if.rst:54
msgid "``if`` is only as useful as the command used as the condition."
msgstr ""

#: ../../../cmds/if.rst:56
msgid "Fish ships a few:"
msgstr ""

#: ../../../cmds/if.rst:58
msgid ":doc:`test` can compare numbers, strings and check paths"
msgstr ""

#: ../../../cmds/if.rst:59
msgid ""
":doc:`string` can perform string operations including wildcard and regular "
"expression matches"
msgstr ""

#: ../../../cmds/if.rst:60
msgid ":doc:`path` can check paths for permissions, existence or type"
msgstr ""

#: ../../../cmds/if.rst:61
msgid ":doc:`contains` can check if an element is in a list"
msgstr ""
