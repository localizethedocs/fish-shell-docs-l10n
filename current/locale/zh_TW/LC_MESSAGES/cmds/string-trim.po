#: ../../../cmds/string-trim.rst:2
msgid "string-trim - remove trailing whitespace"
msgstr ""

#: ../../../cmds/string-trim.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/string-trim.rst:9
msgid ""
"string trim [-l | --left] [-r | --right] [(-c | --chars) CHARS]\n"
"            [-q | --quiet] [STRING ...]"
msgstr ""

#: ../../../cmds/string-trim.rst:17
msgid "Description"
msgstr ""

#: ../../../cmds/string-trim.rst:21
msgid ""
"``string trim`` removes leading and trailing whitespace from each *STRING*. "
"If **-l** or **--left** is given, only leading whitespace is removed. If **-"
"r** or **--right** is given, only trailing whitespace is trimmed."
msgstr ""

#: ../../../cmds/string-trim.rst:23
msgid ""
"The **-c** or **--chars** switch causes the set of characters in *CHARS* to "
"be removed instead of whitespace. This is a set of characters, not a string "
"- if you pass ``-c foo``, it will remove any \"f\" or \"o\", not just "
"\"foo\" as a whole."
msgstr ""

#: ../../../cmds/string-trim.rst:25
msgid "Exit status: 0 if at least one character was trimmed, or 1 otherwise."
msgstr ""

#: ../../../cmds/string-trim.rst:30
msgid "Examples"
msgstr ""

#: ../../../cmds/string-trim.rst:36
msgid ""
">_ string trim ' abc  '\n"
"abc\n"
"\n"
">_ string trim --right --chars=yz xyzzy zany\n"
"x\n"
"zan"
msgstr ""
