#: ../../../cmds/exit.rst:2
msgid "exit - exit the shell"
msgstr ""

#: ../../../cmds/exit.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/exit.rst:7
msgid "exit [CODE]"
msgstr ""

#: ../../../cmds/exit.rst:12
msgid "Description"
msgstr "描述"

#: ../../../cmds/exit.rst:14
msgid ""
"**exit** is a special builtin that causes the shell to exit. Either 255 or "
"the *CODE* supplied is used, whichever is lesser. Otherwise, the exit status "
"will be that of the last command executed."
msgstr ""

#: ../../../cmds/exit.rst:17
msgid ""
"If exit is called while sourcing a file (using the :doc:`source <source>` "
"builtin) the rest of the file will be skipped, but the shell itself will not "
"exit."
msgstr ""

#: ../../../cmds/exit.rst:19
msgid "The **--help** or **-h** option displays help about using this command."
msgstr ""
