#: ../../../cmds/not.rst:2
msgid "not - negate the exit status of a job"
msgstr "not - 反轉工作的退出狀態"

#: ../../../cmds/not.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/not.rst:7
msgid ""
"not COMMAND [OPTIONS ...]\n"
"! COMMAND [OPTIONS ...]"
msgstr ""
"not COMMAND [OPTIONS ...]\n"
"! COMMAND [OPTIONS ...]"

#: ../../../cmds/not.rst:14
msgid "Description"
msgstr "描述"

#: ../../../cmds/not.rst:16
msgid ""
"``not`` negates the exit status of another command. If the exit status is "
"zero, ``not`` returns 1. Otherwise, ``not`` returns 0."
msgstr ""

#: ../../../cmds/not.rst:18
msgid "Some other shells only support the ``!`` alias."
msgstr "有些其他外殼僅支援 ``!`` 別名。"

#: ../../../cmds/not.rst:20
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/not.rst:23
msgid "Example"
msgstr "範例"

#: ../../../cmds/not.rst:25
msgid ""
"The following code reports an error and exits if no file named spoon can be "
"found."
msgstr ""

#: ../../../cmds/not.rst:31
msgid ""
"if not test -f spoon\n"
"    echo There is no spoon\n"
"    exit 1\n"
"end"
msgstr ""
