#: ../../../cmds/fish_status_to_signal.rst:2
msgid "fish_status_to_signal - convert exit codes to human-friendly signals"
msgstr ""

#: ../../../cmds/fish_status_to_signal.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/fish_status_to_signal.rst:7
msgid "fish_status_to_signal NUM"
msgstr ""

#: ../../../cmds/fish_status_to_signal.rst:13
msgid ""
"function fish_prompt\n"
"    echo -n (fish_status_to_signal $pipestatus | string join '|') "
"(prompt_pwd) '$ '\n"
"end"
msgstr ""

#: ../../../cmds/fish_status_to_signal.rst:18
msgid "Description"
msgstr ""

#: ../../../cmds/fish_status_to_signal.rst:20
msgid ""
"``fish_status_to_signal`` converts exit codes to their corresponding human-"
"friendly signals if one exists. This is likely to be useful for prompts in "
"conjunction with the ``$status`` and ``$pipestatus`` variables."
msgstr ""

#: ../../../cmds/fish_status_to_signal.rst:24
msgid "Example"
msgstr "範例"

#: ../../../cmds/fish_status_to_signal.rst:28
msgid ""
">_ sleep 5\n"
"^C⏎\n"
">_ fish_status_to_signal $status\n"
"SIGINT"
msgstr ""
