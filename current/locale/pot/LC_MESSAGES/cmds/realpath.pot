#: ../../../cmds/realpath.rst:2
msgid "realpath - convert a path to an absolute path without symlinks"
msgstr ""

#: ../../../cmds/realpath.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/realpath.rst:7
msgid "realpath [OPTIONS] PATH"
msgstr ""

#: ../../../cmds/realpath.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/realpath.rst:16
msgid ""
"NOTE: This page documents the fish builtin ``realpath``. To see the "
"documentation on any non-fish versions, use ``command man realpath``."
msgstr ""

#: ../../../cmds/realpath.rst:19
msgid ""
":program:`realpath` follows all symbolic links encountered for the provided :"
"envvar:`PATH`, printing the absolute path resolved. :doc:`fish <fish>` "
"provides a :command:`realpath`-alike builtin intended to enrich systems "
"where no such command is installed by default."
msgstr ""

#: ../../../cmds/realpath.rst:21
msgid ""
"If a :command:`realpath` command exists, that will be preferred. ``builtin "
"realpath`` will explicitly use the fish implementation of :command:"
"`realpath`."
msgstr ""

#: ../../../cmds/realpath.rst:24
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/realpath.rst:26
msgid "**-s** or **--no-symlinks**"
msgstr ""

#: ../../../cmds/realpath.rst:27
msgid ""
"Don't resolve symlinks, only make paths absolute, squash multiple slashes "
"and remove trailing slashes."
msgstr ""

#: ../../../cmds/realpath.rst:29
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/realpath.rst:30
msgid "Displays help about using this command."
msgstr ""
