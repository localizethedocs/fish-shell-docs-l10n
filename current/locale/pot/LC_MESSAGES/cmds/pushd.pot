#: ../../../cmds/pushd.rst:2
msgid "pushd - push directory to directory stack"
msgstr ""

#: ../../../cmds/pushd.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/pushd.rst:7
msgid "pushd DIRECTORY"
msgstr ""

#: ../../../cmds/pushd.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/pushd.rst:14
msgid ""
"The ``pushd`` function adds *DIRECTORY* to the top of the :ref:`directory "
"stack <directory-stack>` and makes it the current working directory. :doc:"
"`popd <popd>` will pop it off and return to the original directory."
msgstr ""

#: ../../../cmds/pushd.rst:16
msgid "Without arguments, it exchanges the top two directories in the stack."
msgstr ""

#: ../../../cmds/pushd.rst:18
msgid ""
"``pushd +NUMBER`` rotates the stack counter-clockwise i.e. from bottom to top"
msgstr ""

#: ../../../cmds/pushd.rst:20
msgid "``pushd -NUMBER`` rotates clockwise i.e. top to bottom."
msgstr ""

#: ../../../cmds/pushd.rst:22
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/pushd.rst:25
msgid "Example"
msgstr ""

#: ../../../cmds/pushd.rst:29
msgid ""
"cd ~/dir1\n"
"pushd ~/dir2\n"
"pushd ~/dir3\n"
"# Working directory is now ~/dir3\n"
"# Directory stack contains ~/dir2 ~/dir1\n"
"\n"
"pushd /tmp\n"
"# Working directory is now /tmp\n"
"# Directory stack contains ~/dir3 ~/dir2 ~/dir1\n"
"\n"
"pushd +1\n"
"# Working directory is now ~/dir3\n"
"# Directory stack contains ~/dir2 ~/dir1 /tmp\n"
"\n"
"popd\n"
"# Working directory is now ~/dir2\n"
"# Directory stack contains ~/dir1 /tmp"
msgstr ""

