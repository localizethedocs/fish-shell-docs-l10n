#: ../../../cmds/nextd.rst:2
msgid "nextd - move forward through directory history"
msgstr ""

#: ../../../cmds/nextd.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/nextd.rst:7
msgid "nextd [-l | --list] [POS]"
msgstr ""

#: ../../../cmds/nextd.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/nextd.rst:14
msgid ""
"``nextd`` moves forwards *POS* positions in the :ref:`history of visited "
"directories <directory-history>`; if the end of the history has been hit, a "
"warning is printed."
msgstr ""

#: ../../../cmds/nextd.rst:16
msgid ""
"If the **-l** or **--list** option is specified, the current directory "
"history is also displayed."
msgstr ""

#: ../../../cmds/nextd.rst:18
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/nextd.rst:20
msgid ""
"Note that the ``cd`` command limits directory history to the 25 most "
"recently visited directories. The history is stored in the :envvar:`dirprev` "
"and :envvar:`dirnext` variables which this command manipulates."
msgstr ""

#: ../../../cmds/nextd.rst:23
msgid "Example"
msgstr ""

#: ../../../cmds/nextd.rst:27
msgid ""
"cd /usr/src\n"
"# Working directory is now /usr/src\n"
"\n"
"cd /usr/src/fish-shell\n"
"# Working directory is now /usr/src/fish-shell\n"
"\n"
"prevd\n"
"# Working directory is now /usr/src\n"
"\n"
"nextd\n"
"# Working directory is now /usr/src/fish-shell"
msgstr ""

#: ../../../cmds/nextd.rst:40
msgid "See Also"
msgstr ""

#: ../../../cmds/nextd.rst:42
msgid ""
"the :doc:`cdh <cdh>` command to display a prompt to quickly navigate the "
"history"
msgstr ""

#: ../../../cmds/nextd.rst:43
msgid "the :doc:`dirh <dirh>` command to print the directory history"
msgstr ""

#: ../../../cmds/nextd.rst:44
msgid "the :doc:`prevd <prevd>` command to move backward"
msgstr ""
