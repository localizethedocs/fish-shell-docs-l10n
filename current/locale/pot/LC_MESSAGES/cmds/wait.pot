#: ../../../cmds/wait.rst:2
msgid "wait - wait for jobs to complete"
msgstr ""

#: ../../../cmds/wait.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/wait.rst:7
msgid "wait [-n | --any] [PID | PROCESS_NAME] ..."
msgstr ""

#: ../../../cmds/wait.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/wait.rst:16
msgid ""
"NOTE: This page documents the fish builtin ``wait``. To see the "
"documentation on any non-fish versions, use ``command man wait``."
msgstr ""

#: ../../../cmds/wait.rst:19
msgid "``wait`` waits for child jobs to complete."
msgstr ""

#: ../../../cmds/wait.rst:21
msgid ""
"If a *PID* is specified, the command waits for the job that the process with "
"that process ID belongs to."
msgstr ""

#: ../../../cmds/wait.rst:23
msgid ""
"If a *PROCESS_NAME* is specified, the command waits for the jobs that the "
"matched processes belong to."
msgstr ""

#: ../../../cmds/wait.rst:25
msgid ""
"If neither a pid nor a process name is specified, the command waits for all "
"background jobs."
msgstr ""

#: ../../../cmds/wait.rst:27
msgid ""
"If the **-n** or **--any** flag is provided, the command returns as soon as "
"the first job completes. If it is not provided, it returns after all jobs "
"complete."
msgstr ""

#: ../../../cmds/wait.rst:29
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/wait.rst:32
msgid "Example"
msgstr ""

#: ../../../cmds/wait.rst:36
msgid ""
"sleep 10 &\n"
"wait $last_pid"
msgstr ""

#: ../../../cmds/wait.rst:39
msgid "spawns ``sleep`` in the background, and then waits until it finishes."
msgstr ""

#: ../../../cmds/wait.rst:44
msgid ""
"for i in (seq 1 5); sleep 10 &; end\n"
"wait"
msgstr ""

#: ../../../cmds/wait.rst:47
msgid ""
"spawns five jobs in the background, and then waits until all of them finish."
msgstr ""

#: ../../../cmds/wait.rst:52
msgid ""
"for i in (seq 1 5); sleep 10 &; end\n"
"hoge &\n"
"wait sleep"
msgstr ""

#: ../../../cmds/wait.rst:56
msgid ""
"spawns five ``sleep`` jobs and ``hoge`` in the background, and then waits "
"until all ``sleep``\\s finish, and doesn't wait for ``hoge``."
msgstr ""
