#: ../../../cmds/set.rst:2
msgid "set - display and change shell variables"
msgstr ""

#: ../../../cmds/set.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/set.rst:7
msgid ""
"set\n"
"set (-f | --function) (-l | --local) (-g | --global) (-U | --universal) [--"
"no-event]\n"
"set [-Uflg] NAME [VALUE ...]\n"
"set [-Uflg] NAME[[INDEX ...]] [VALUE ...]\n"
"set (-x | --export) (-u | --unexport) [-Uflg] NAME [VALUE ...]\n"
"set (-a | --append) (-p | --prepend) [-Uflg] NAME VALUE ...\n"
"set (-e | --erase) [-Uflg] [-xu] [NAME][[INDEX]] ...]\n"
"set (-q | --query) [-Uflg] [-xu] [NAME][[INDEX]] ...]\n"
"set (-S | --show) (-L | --long) [NAME ...]"
msgstr ""

#: ../../../cmds/set.rst:20
msgid "Description"
msgstr ""

#: ../../../cmds/set.rst:22
msgid "``set`` manipulates :ref:`shell variables <variables>`."
msgstr ""

#: ../../../cmds/set.rst:24
msgid ""
"If both *NAME* and *VALUE* are provided, ``set`` assigns any values to "
"variable *NAME*. Variables in fish are :ref:`lists <variables-lists>`, "
"multiple values are allowed. One or more variable *INDEX* can be specified "
"including ranges (not for all options.)"
msgstr ""

#: ../../../cmds/set.rst:28
msgid "If no *VALUE* is given, the variable will be set to the empty list."
msgstr ""

#: ../../../cmds/set.rst:30
msgid ""
"If ``set`` is ran without arguments, it prints the names and values of all "
"shell variables in sorted order. Passing :ref:`scope <variables-scope>` or :"
"ref:`export <variables-export>` flags allows filtering this to only matching "
"variables, so ``set --local`` would only show local variables."
msgstr ""

#: ../../../cmds/set.rst:33
msgid ""
"With ``--erase`` and optionally a scope flag ``set`` will erase the matching "
"variable (or the variable of that name in the smallest possible scope)."
msgstr ""

#: ../../../cmds/set.rst:35
msgid ""
"With ``--show``, ``set`` will describe the given variable names, explaining "
"how they have been defined - in which scope with which values and options."
msgstr ""

#: ../../../cmds/set.rst:37
msgid "The following options control variable scope:"
msgstr ""

#: ../../../cmds/set.rst:39
msgid "**-U** or **--universal**"
msgstr ""

#: ../../../cmds/set.rst:40
msgid ""
"Sets a universal variable. The variable will be immediately available to all "
"the user's ``fish`` instances on the machine, and will be persisted across "
"restarts of the shell."
msgstr ""

#: ../../../cmds/set.rst:43
msgid "**-f** or **--function**"
msgstr ""

#: ../../../cmds/set.rst:44
msgid ""
"Sets a variable scoped to the executing function. It is erased when the "
"function ends."
msgstr ""

#: ../../../cmds/set.rst:47
msgid "**-l** or **--local**"
msgstr ""

#: ../../../cmds/set.rst:48
msgid ""
"Sets a locally-scoped variable in this block. It is erased when the block "
"ends. Outside of a block, this is the same as **--function**."
msgstr ""

#: ../../../cmds/set.rst:52
msgid "**-g** or **--global**"
msgstr ""

#: ../../../cmds/set.rst:53
msgid ""
"Sets a globally-scoped variable. Global variables are available to all "
"functions running in the same shell. They can be modified or erased."
msgstr ""

#: ../../../cmds/set.rst:57
msgid "These options modify how variables operate:"
msgstr ""

#: ../../../cmds/set.rst:59
msgid "**--export** or **-x**"
msgstr ""

#: ../../../cmds/set.rst:60
msgid ""
"Causes the specified shell variable to be exported to child processes "
"(making it an \"environment variable\")."
msgstr ""

#: ../../../cmds/set.rst:62
msgid "**--unexport** or **-u**"
msgstr ""

#: ../../../cmds/set.rst:63
msgid ""
"Causes the specified shell variable to NOT be exported to child processes."
msgstr ""

#: ../../../cmds/set.rst:65
msgid "**--path**"
msgstr ""

#: ../../../cmds/set.rst:66
msgid ""
"Treat specified variable as a :ref:`path variable <variables-path>`; "
"variable will be split on colons (``:``) and will be displayed joined by "
"colons when quoted (``echo \"$PATH\"``) or exported."
msgstr ""

#: ../../../cmds/set.rst:68
msgid "**--unpath**"
msgstr ""

#: ../../../cmds/set.rst:69
msgid ""
"Causes variable to no longer be treated as a :ref:`path variable <variables-"
"path>`. Note: variables ending in \"PATH\" are automatically path variables."
msgstr ""

#: ../../../cmds/set.rst:72
msgid "Further options:"
msgstr ""

#: ../../../cmds/set.rst:74
msgid "**-a** or **--append** *NAME* *VALUE* ..."
msgstr ""

#: ../../../cmds/set.rst:75
msgid ""
"Appends *VALUES* to the current set of values for variable **NAME**. Can be "
"used with **--prepend** to both append and prepend at the same time. This "
"cannot be used when assigning to a variable slice."
msgstr ""

#: ../../../cmds/set.rst:79
msgid "**-p** or **--prepend** *NAME* *VALUE* ..."
msgstr ""

#: ../../../cmds/set.rst:80
msgid ""
"Prepends *VALUES* to the current set of values for variable **NAME**. This "
"can be used with **--append** to both append and prepend at the same time. "
"This cannot be used when assigning to a variable slice."
msgstr ""

#: ../../../cmds/set.rst:84
msgid "**-e** or **--erase** *NAME*\\[*INDEX*\\]"
msgstr ""

#: ../../../cmds/set.rst:85
msgid ""
"Causes the specified shell variables to be erased. Supports erasing from "
"multiple scopes at once. Individual items in a variable at *INDEX* in "
"brackets can be specified."
msgstr ""

#: ../../../cmds/set.rst:89
msgid "**-q** or **--query** *NAME*\\[*INDEX*\\]"
msgstr ""

#: ../../../cmds/set.rst:90
msgid ""
"Test if the specified variable names are defined. If an *INDEX* is provided, "
"check for items at that slot. With a given scope (like **--global**) or "
"attribute (like **--exported** or **--path**) check only variables that "
"match. Does not output anything, but the shell status is set to the number "
"of variables specified that were not defined, up to a maximum of 255. If no "
"variable was given, it also returns 255."
msgstr ""

#: ../../../cmds/set.rst:96
msgid "**-n** or **--names**"
msgstr ""

#: ../../../cmds/set.rst:97
msgid ""
"List only the names of all defined variables, not their value. The names are "
"guaranteed to be sorted."
msgstr ""

#: ../../../cmds/set.rst:100
msgid "**-S** or **--show**"
msgstr ""

#: ../../../cmds/set.rst:101
msgid ""
"Shows information about the given variables. If no variable names are given "
"then all variables are shown in sorted order. It shows the scopes the given "
"variables are set in, along with the values in each and whether or not it is "
"exported. No other flags can be used with this option."
msgstr ""

#: ../../../cmds/set.rst:106
msgid "**--no-event**"
msgstr ""

#: ../../../cmds/set.rst:107
msgid ""
"Don't generate a variable change event when setting or erasing a variable. "
"We recommend using this carefully because the event handlers are usually set "
"up for a reason. Possible uses include modifying the variable inside a "
"variable handler."
msgstr ""

#: ../../../cmds/set.rst:111
msgid "**-L** or **--long**"
msgstr ""

#: ../../../cmds/set.rst:112
msgid "Do not abbreviate long values when printing set variables."
msgstr ""

#: ../../../cmds/set.rst:114
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/set.rst:115
msgid "Displays help about using this command."
msgstr ""

#: ../../../cmds/set.rst:117
msgid ""
"If a variable is set to more than one value, the variable will be a list "
"with the specified elements. If a variable is set to zero elements, it will "
"become a list with zero elements."
msgstr ""

#: ../../../cmds/set.rst:120
msgid ""
"If the variable name is one or more list elements, such as ``PATH[1 3 7]``, "
"only those list elements specified will be changed. If you specify a "
"negative index when expanding or assigning to a list variable, the index "
"will be calculated from the end of the list. For example, the index -1 means "
"the last index of a list."
msgstr ""

#: ../../../cmds/set.rst:124
msgid "The scoping rules when creating or updating a variable are:"
msgstr ""

#: ../../../cmds/set.rst:126
msgid ""
"Variables may be explicitly set as universal, global, function, or local. "
"Variables with the same name but in a different scope will not be changed."
msgstr ""

#: ../../../cmds/set.rst:129
msgid ""
"If the scope of a variable is not explicitly set *but a variable by that "
"name has been previously defined*, the scope of the existing variable is "
"used. If the variable is already defined in multiple scopes, the variable "
"with the narrowest scope will be updated."
msgstr ""

#: ../../../cmds/set.rst:132
msgid ""
"If a variable's scope is not explicitly set and there is no existing "
"variable by that name, the variable will be local to the currently executing "
"function. Note that this is different from using the ``-l`` or ``--local`` "
"flag, in which case the variable will be local to the most-inner currently "
"executing block, while without them the variable will be local to the "
"function as a whole. If no function is executing, the variable will be set "
"in the global scope."
msgstr ""

#: ../../../cmds/set.rst:137
msgid ""
"The exporting rules when creating or updating a variable are identical to "
"the scoping rules for variables:"
msgstr ""

#: ../../../cmds/set.rst:139
msgid ""
"Variables may be explicitly set to either exported or not exported. When an "
"exported variable goes out of scope, it is unexported."
msgstr ""

#: ../../../cmds/set.rst:142
msgid ""
"If a variable is not explicitly set to be exported or not exported, but has "
"been previously defined, the previous exporting rule for the variable is "
"kept."
msgstr ""

#: ../../../cmds/set.rst:144
msgid ""
"If a variable is not explicitly set to be either exported or unexported and "
"has never before been defined, the variable will not be exported."
msgstr ""

#: ../../../cmds/set.rst:146
msgid ""
"In query mode, the scope to be examined can be specified. Whether the "
"variable has to be a path variable or exported can also be specified."
msgstr ""

#: ../../../cmds/set.rst:149
msgid ""
"In erase mode, if variable indices are specified, only the specified slices "
"of the list variable will be erased."
msgstr ""

#: ../../../cmds/set.rst:151
msgid ""
"``set`` requires all options to come before any other arguments. For "
"example, ``set flags -l`` will have the effect of setting the value of the "
"variable :envvar:`flags` to '-l', not making the variable local."
msgstr ""

#: ../../../cmds/set.rst:155
msgid "Exit status"
msgstr ""

#: ../../../cmds/set.rst:157
msgid ""
"In assignment mode, ``set`` does not modify the exit status, but passes "
"along whatever :envvar:`status` was set, including by command substitutions. "
"This allows capturing the output and exit status of a subcommand, like in "
"``if set output (command)``."
msgstr ""

#: ../../../cmds/set.rst:160
msgid ""
"In query mode, the exit status is the number of variables that were not "
"found."
msgstr ""

#: ../../../cmds/set.rst:162
msgid ""
"In erase mode, ``set`` exits with a zero exit status in case of success, "
"with a non-zero exit status if the commandline was invalid, if any of the "
"variables did not exist or was a :ref:`special read-only variable <variables-"
"special>`."
msgstr ""

#: ../../../cmds/set.rst:166
msgid "Examples"
msgstr ""

#: ../../../cmds/set.rst:168
msgid "Print all global, exported variables::"
msgstr ""

#: ../../../cmds/set.rst:170
msgid "> set -gx"
msgstr ""

#: ../../../cmds/set.rst:172
msgid "Set the value of the variable _$foo_ to be 'hi'.::"
msgstr ""

#: ../../../cmds/set.rst:174
msgid "> set foo hi"
msgstr ""

#: ../../../cmds/set.rst:176
msgid "Append the value \"there\" to the variable $foo::"
msgstr ""

#: ../../../cmds/set.rst:178
msgid "> set -a foo there"
msgstr ""

#: ../../../cmds/set.rst:180
msgid "Remove _$smurf_ from the scope::"
msgstr ""

#: ../../../cmds/set.rst:182
msgid "> set -e smurf"
msgstr ""

#: ../../../cmds/set.rst:184
msgid "Remove _$smurf_ from the global and universal scopes::"
msgstr ""

#: ../../../cmds/set.rst:186
msgid "> set -e -Ug smurf"
msgstr ""

#: ../../../cmds/set.rst:188
msgid "Change the fourth element of the $PATH list to ~/bin::"
msgstr ""

#: ../../../cmds/set.rst:190
msgid "> set PATH[4] ~/bin"
msgstr ""

#: ../../../cmds/set.rst:192
msgid "Outputs the path to Python if ``type -p`` returns true::"
msgstr ""

#: ../../../cmds/set.rst:194
msgid ""
"if set python_path (type -p python)\n"
"    echo \"Python is at $python_path\"\n"
"end"
msgstr ""

#: ../../../cmds/set.rst:198
msgid ""
"Setting a variable doesn't modify $status; a command substitution still "
"will, though::"
msgstr ""

#: ../../../cmds/set.rst:200
msgid ""
"> echo $status\n"
"0\n"
"> false\n"
"> set foo bar\n"
"> echo $status\n"
"1\n"
"> true\n"
"> set foo banana (false)\n"
"> echo $status\n"
"1"
msgstr ""

#: ../../../cmds/set.rst:211
msgid ""
"``VAR=VALUE command`` sets a variable for just one command, like other "
"shells. This runs fish with a temporary home directory::"
msgstr ""

#: ../../../cmds/set.rst:214
msgid "> HOME=(mktemp -d) fish"
msgstr ""

#: ../../../cmds/set.rst:216
msgid "(which is essentially the same as)::"
msgstr ""

#: ../../../cmds/set.rst:218
msgid "> begin; set -lx HOME (mktemp -d); fish; end"
msgstr ""

#: ../../../cmds/set.rst:221
msgid "Notes"
msgstr ""

#: ../../../cmds/set.rst:222
msgid ""
"Fish versions prior to 3.0 supported the syntax ``set PATH[1] PATH[4] /bin /"
"sbin``, which worked like ``set PATH[1 4] /bin /sbin``."
msgstr ""
