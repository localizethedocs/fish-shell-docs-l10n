#: ../../../cmds/builtin.rst:2
msgid "builtin - run a builtin command"
msgstr ""

#: ../../../cmds/builtin.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/builtin.rst:7
msgid ""
"builtin [OPTIONS] BUILTINNAME\n"
"builtin --query BUILTINNAME ...\n"
"builtin --names"
msgstr ""

#: ../../../cmds/builtin.rst:14
msgid "Description"
msgstr "描述"

#: ../../../cmds/builtin.rst:16
msgid ""
"``builtin`` forces the shell to use a builtin command named *BUILTIN*, "
"rather than a function or external program."
msgstr ""

#: ../../../cmds/builtin.rst:18
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/builtin.rst:20
msgid "**-n** or **--names**"
msgstr ""

#: ../../../cmds/builtin.rst:21
msgid "Lists the names of all defined builtins."
msgstr ""

#: ../../../cmds/builtin.rst:23
msgid "**-q** or **--query** *BUILTIN*"
msgstr ""

#: ../../../cmds/builtin.rst:24
msgid ""
"Tests if any of the specified builtins exist. If any exist, it returns 0, 1 "
"otherwise."
msgstr ""

#: ../../../cmds/builtin.rst:26
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/builtin.rst:27
msgid "Displays help about using this command."
msgstr "顯示此指令的幫助資訊。"

#: ../../../cmds/builtin.rst:30
msgid "Example"
msgstr "範例"

#: ../../../cmds/builtin.rst:34
msgid ""
"builtin jobs\n"
"# executes the jobs builtin, even if a function named jobs exists"
msgstr ""
