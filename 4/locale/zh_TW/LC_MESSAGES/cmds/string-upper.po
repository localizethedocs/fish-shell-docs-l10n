#: ../../../cmds/string-upper.rst:2
msgid "string-upper - convert strings to uppercase"
msgstr ""

#: ../../../cmds/string-upper.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/string-upper.rst:9
msgid "string upper [-q | --quiet] [STRING ...]"
msgstr ""

#: ../../../cmds/string-upper.rst:16
msgid "Description"
msgstr ""

#: ../../../cmds/string-upper.rst:20
msgid ""
"``string upper`` converts each string argument to uppercase. Exit status: 0 "
"if at least one string was converted to uppercase, else 1. This means that "
"in conjunction with the **-q** flag you can readily test whether a string is "
"already uppercase."
msgstr ""
