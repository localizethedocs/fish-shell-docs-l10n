#: ../../../cmds/vared.rst:2
msgid "vared - interactively edit the value of an environment variable"
msgstr ""

#: ../../../cmds/vared.rst:5
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/vared.rst:7
msgid "vared VARIABLE_NAME"
msgstr ""

#: ../../../cmds/vared.rst:12
msgid "Description"
msgstr "描述"

#: ../../../cmds/vared.rst:14
msgid ""
"``vared`` is used to interactively edit the value of an environment "
"variable. Array variables as a whole can not be edited using ``vared``, but "
"individual list elements can."
msgstr ""

#: ../../../cmds/vared.rst:16
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/vared.rst:19
msgid "Example"
msgstr "範例"

#: ../../../cmds/vared.rst:21
msgid "``vared PATH[3]`` edits the third element of the PATH list"
msgstr ""
