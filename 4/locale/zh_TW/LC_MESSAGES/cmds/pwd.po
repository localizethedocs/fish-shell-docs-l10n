msgid "Description"
msgstr "描述"

#: ../../../cmds/pwd.rst:18
msgid ""
"NOTE: This page documents the fish builtin ``pwd``. To see the documentation "
"on any non-fish versions, use ``command man pwd``."
msgstr ""

#: ../../../cmds/pwd.rst:21
msgid "``pwd`` outputs (prints) the current working directory."
msgstr ""

#: ../../../cmds/pwd.rst:23
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/pwd.rst:25
msgid "**-L** or **--logical**"
msgstr ""

#: ../../../cmds/pwd.rst:26
msgid ""
"Output the logical working directory, without resolving symlinks (default "
"behavior)."
msgstr ""

#: ../../../cmds/pwd.rst:28
msgid "**-P** or **--physical**"
msgstr ""

#: ../../../cmds/pwd.rst:29
msgid "Output the physical working directory, with symlinks resolved."
msgstr ""

#: ../../../cmds/pwd.rst:31
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/pwd.rst:32
msgid "Displays help about using this command."
msgstr "顯示此指令的幫助資訊。"

