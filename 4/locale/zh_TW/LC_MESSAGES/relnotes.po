msgid "fish 4.0.8 (released September 18, 2025)"
msgstr ""

#: ../../../../CHANGELOG.rst:453
msgid ""
"This release fixes a regression in 4.0.6 that caused user bindings to be "
"shadowed by either fish's or a plugin's bindings (:issue:`11803`)."
