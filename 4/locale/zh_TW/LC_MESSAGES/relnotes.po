#: ../../../../CHANGELOG.rst:24
msgid "fish 4.4.0 (released February 03, 2026)"
msgstr ""

#: ../../../../CHANGELOG.rst:28
msgid "The default fossil prompt has been disabled (:issue:`12342`)."
msgstr ""

#: ../../../../CHANGELOG.rst:32
msgid ""
"The ``bind`` builtin lists mappings from all modes if ``--mode`` is not "
"provided (:issue:`12214`)."
msgstr ""

#: ../../../../CHANGELOG.rst:33
msgid ""
"Line-wise autosuggestions that don't start a command are no longer shown "
"(739b82c34db, 58e7a50de8a)."
msgstr ""

#: ../../../../CHANGELOG.rst:34
msgid ""
"Builtin ``history`` now assumes that :envvar:`PAGER` supports ANSI color "
"sequences."
msgstr ""

#: ../../../../CHANGELOG.rst:35
msgid ""
"fish now clears the terminal's ``FLUSHO`` flag when acquiring control of the "
"terminal, to fix an issue caused by pressing :kbd:`ctrl-o` on macOS (:issue:"
"`12304`)."
msgstr ""

#: ../../../../CHANGELOG.rst:38 ../../../../CHANGELOG.rst:132
#: ../../../../CHANGELOG.rst:327 ../../../../CHANGELOG.rst:705
