msgid ""
"The removal of pre-built HTML docs from tarballs revealed that cross "
"compilation is broken because we use ``${CMAKE_BINARY_DIR}/fish_indent`` for "
"building HTML docs. As a workaround, the new CMake build option "
"``FISH_INDENT_FOR_BUILDING_DOCS`` can be set to the path of a runnable "
"``fish_indent`` binary."
msgstr ""

#: ../../../../CHANGELOG.rst:90
msgid "fish 4.3.1 (released December 28, 2025)"
msgstr ""

#: ../../../../CHANGELOG.rst:92
msgid "This release fixes the following problem identified in 4.3.0:"
msgstr ""

