#: ../../../cmds/commandline.rst:2
msgid "commandline - set or get the current command line buffer"
msgstr ""

#: ../../../cmds/commandline.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/commandline.rst:7
msgid "commandline [OPTIONS] [CMD]"
msgstr ""

#: ../../../cmds/commandline.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/commandline.rst:14
msgid ""
"``commandline`` can be used to set or get the current contents of the "
"command line buffer."
msgstr ""

#: ../../../cmds/commandline.rst:16
msgid ""
"With no parameters, ``commandline`` returns the current value of the command "
"line."
msgstr ""

#: ../../../cmds/commandline.rst:18
msgid ""
"With **CMD** specified, the command line buffer is erased and replaced with "
"the contents of **CMD**."
msgstr ""

#: ../../../cmds/commandline.rst:20
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/commandline.rst:22
msgid "**-C** or **--cursor**"
msgstr ""

#: ../../../cmds/commandline.rst:23
msgid ""
"Set or get the current cursor position, not the contents of the buffer. If "
"no argument is given, the current cursor position is printed, otherwise the "
"argument is interpreted as the new cursor position. If one of the options **-"
"j**, **-p** or **-t** is given, the position is relative to the respective "
"substring instead of the entire command line buffer."
msgstr ""

#: ../../../cmds/commandline.rst:27
msgid "**-B** or **--selection-start**"
msgstr ""

#: ../../../cmds/commandline.rst:28
msgid "Get current position of the selection start in the buffer."
msgstr ""

#: ../../../cmds/commandline.rst:30
msgid "**-E** or **--selection-end**"
msgstr ""

#: ../../../cmds/commandline.rst:31
msgid "Get current position of the selection end in the buffer."
msgstr ""

#: ../../../cmds/commandline.rst:33
msgid "**-f** or **--function**"
msgstr ""

#: ../../../cmds/commandline.rst:34
msgid ""
"Causes any additional arguments to be interpreted as input functions, and "
"puts them into the queue, so that they will be read before any additional "
"actual key presses are. This option cannot be combined with any other "
"option. See :doc:`bind <bind>` for a list of input functions."
msgstr ""

#: ../../../cmds/commandline.rst:38
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/commandline.rst:39
msgid "Displays help about using this command."
msgstr ""

#: ../../../cmds/commandline.rst:41
msgid ""
"The following options change the way ``commandline`` updates the command "
"line buffer:"
msgstr ""

#: ../../../cmds/commandline.rst:43
msgid "**-a** or **--append**"
msgstr ""

#: ../../../cmds/commandline.rst:44
msgid ""
"Do not remove the current commandline, append the specified string at the "
"end of it."
msgstr ""

#: ../../../cmds/commandline.rst:46
msgid "**-i**, **--insert** or **--insert-smart**"
msgstr ""

#: ../../../cmds/commandline.rst:47
msgid ""
"Do not remove the current commandline, insert the specified string at the "
"current cursor position. The **--insert-smart** option turns on a Do-What-I-"
"Mean (DWIM) mode: it strips any **$** prefix from the first command on each "
"line."
msgstr ""

#: ../../../cmds/commandline.rst:50
msgid "**-r** or **--replace**"
msgstr ""

#: ../../../cmds/commandline.rst:51
msgid ""
"Remove the current commandline and replace it with the specified string "
"(default)"
msgstr ""

#: ../../../cmds/commandline.rst:53
msgid ""
"The following options change what part of the commandline is printed or "
"updated:"
msgstr ""

#: ../../../cmds/commandline.rst:55
msgid "**-b** or **--current-buffer**"
msgstr ""

#: ../../../cmds/commandline.rst:56
msgid ""
"Select the entire commandline, not including any displayed autosuggestion "
"(default)."
msgstr ""

#: ../../../cmds/commandline.rst:58
msgid "**-j** or **--current-job**"
msgstr ""

#: ../../../cmds/commandline.rst:59
msgid ""
"Select the current job - a **job** here is one pipeline. Stops at logical "
"operators or terminators (**;**, **&**, and newlines)."
msgstr ""

#: ../../../cmds/commandline.rst:62
msgid "**-p** or **--current-process**"
msgstr ""

#: ../../../cmds/commandline.rst:63
msgid ""
"Select the current process - a **process** here is one command. Stops at "
"logical operators, terminators, and pipes."
msgstr ""

#: ../../../cmds/commandline.rst:66
msgid "**-s** or **--current-selection**"
msgstr ""

#: ../../../cmds/commandline.rst:67
msgid "Selects the current selection"
msgstr ""

#: ../../../cmds/commandline.rst:69
msgid "**-t** or **--current-token**"
msgstr ""

#: ../../../cmds/commandline.rst:70
msgid "Selects the current token"
msgstr ""

#: ../../../cmds/commandline.rst:72
msgid "**--search-field**"
msgstr ""

#: ../../../cmds/commandline.rst:73
msgid ""
"Use the pager search field instead of the command line. Returns false if the "
"search field is not shown."
msgstr ""

#: ../../../cmds/commandline.rst:75
msgid "**--input=INPUT**"
msgstr ""

#: ../../../cmds/commandline.rst:76
msgid ""
"Operate on this string instead of the commandline. Useful for using options "
"like **--tokens-expanded**."
msgstr ""

#: ../../../cmds/commandline.rst:78
msgid ""
"The following options change the way ``commandline`` prints the current "
"commandline buffer:"
msgstr ""

#: ../../../cmds/commandline.rst:80
msgid "**-c** or **--cut-at-cursor**"
msgstr ""

#: ../../../cmds/commandline.rst:81
msgid ""
"Only print selection up until the current cursor position. If combined with "
"``--tokens-expanded``, this will print up until the last completed token - "
"excluding the token the cursor is in. This is typically what you would want "
"for instance in completions. To get both, use both ``commandline --cut-at-"
"cursor --tokens-expanded; commandline --cut-at-cursor --current-token``, or "
"``commandline -cx; commandline -ct`` for short."
msgstr ""

#: ../../../cmds/commandline.rst:87
msgid "**-x** or **--tokens-expanded**"
msgstr ""

#: ../../../cmds/commandline.rst:88
msgid ""
"Perform argument expansion on the selection and print one argument per line. "
"Command substitutions are not expanded but forwarded as-is."
msgstr ""

#: ../../../cmds/commandline.rst:91
msgid "**-o**, **tokenize**, **--tokens-raw**"
msgstr ""

#: ../../../cmds/commandline.rst:92
msgid "Deprecated; do not use."
msgstr ""

#: ../../../cmds/commandline.rst:94
msgid ""
"If ``commandline`` is called during a call to complete a given string using "
"``complete -C STRING``, ``commandline`` will consider the specified string "
"to be the current contents of the command line."
msgstr ""

#: ../../../cmds/commandline.rst:96
msgid "The following options output metadata about the commandline state:"
msgstr ""

#: ../../../cmds/commandline.rst:98
msgid "**-L** or **--line**"
msgstr ""

#: ../../../cmds/commandline.rst:99
msgid ""
"If no argument is given, print the line that the cursor is on, with the "
"topmost line starting at 1. Otherwise, set the cursor to the given line."
msgstr ""

#: ../../../cmds/commandline.rst:102
msgid "**--column**"
msgstr ""

#: ../../../cmds/commandline.rst:103
msgid ""
"If no argument is given, print the 1-based offset from the start of the line "
"to the cursor position in Unicode code points. Otherwise, set the cursor to "
"the given code point offset."
msgstr ""

#: ../../../cmds/commandline.rst:106
msgid "**-S** or **--search-mode**"
msgstr ""

#: ../../../cmds/commandline.rst:107
msgid "Evaluates to true if the commandline is performing a history search."
msgstr ""

#: ../../../cmds/commandline.rst:109
msgid "**-P** or **--paging-mode**"
msgstr ""

#: ../../../cmds/commandline.rst:110
msgid ""
"Evaluates to true if the commandline is showing pager contents, such as tab "
"completions."
msgstr ""

#: ../../../cmds/commandline.rst:112
msgid "**--paging-full-mode**"
msgstr ""

#: ../../../cmds/commandline.rst:113
msgid ""
"Evaluates to true if the commandline is showing pager contents, such as tab "
"completions and all lines are shown (no \"<n> more rows\" message)."
msgstr ""

#: ../../../cmds/commandline.rst:115
msgid "**--is-valid**"
msgstr ""

#: ../../../cmds/commandline.rst:116
msgid ""
"Returns true when the commandline is syntactically valid and complete. If it "
"is, it would be executed when the ``execute`` bind function is called. If "
"the commandline is incomplete, return 2, if erroneous, return 1."
msgstr ""

#: ../../../cmds/commandline.rst:120
msgid "**--showing-suggestion**"
msgstr ""

#: ../../../cmds/commandline.rst:121
msgid ""
"Evaluates to true (i.e. returns 0) when the shell is currently showing an "
"automatic history completion/suggestion, available to be consumed via one of "
"the `forward-` bindings. For example, can be used to determine if moving the "
"cursor to the right when already at the end of the line would have no effect "
"or if it would cause a completion to be accepted (note that `forward-char-"
"passive` does this automatically)."
msgstr ""

#: ../../../cmds/commandline.rst:125
msgid "Example"
msgstr ""

#: ../../../cmds/commandline.rst:127
msgid ""
"``commandline -j $history[3]`` replaces the job under the cursor with the "
"third item from the command line history."
msgstr ""

#: ../../../cmds/commandline.rst:129
msgid "If the commandline contains"
msgstr ""

#: ../../../cmds/commandline.rst:134
msgid ">_ echo $flounder >&2 | less; and echo $catfish"
msgstr ""

#: ../../../cmds/commandline.rst:137
msgid "(with the cursor on the \"o\" of \"flounder\")"
msgstr ""

#: ../../../cmds/commandline.rst:139
msgid ""
"The ``echo $flounder >&`` is the first process, ``less`` the second and "
"``and echo $catfish`` the third."
msgstr ""

#: ../../../cmds/commandline.rst:141
msgid ""
"``echo $flounder >&2 | less`` is the first job, ``and echo $catfish`` the "
"second."
msgstr ""

#: ../../../cmds/commandline.rst:143
msgid "**$flounder** is the current token."
msgstr ""

#: ../../../cmds/commandline.rst:145
msgid "The most common use for something like completions is"
msgstr ""

#: ../../../cmds/commandline.rst:149
msgid "set -l tokens (commandline -xpc)"
msgstr ""

#: ../../../cmds/commandline.rst:151
msgid ""
"which gives the current *process* (what is being completed), tokenized into "
"separate entries, up to but excluding the currently being completed token"
msgstr ""

#: ../../../cmds/commandline.rst:153
msgid "If you are then also interested in the in-progress token, add"
msgstr ""

#: ../../../cmds/commandline.rst:157
msgid "set -l current (commandline -ct)"
msgstr ""

#: ../../../cmds/commandline.rst:159
msgid ""
"Note that this makes it easy to render fish's infix matching moot - if "
"possible it's best if the completions just print all possibilities and leave "
"the matching to the current token up to fish's logic."
msgstr ""

#: ../../../cmds/commandline.rst:161
msgid "More examples:"
msgstr ""

#: ../../../cmds/commandline.rst:165
msgid ""
">_ commandline -t\n"
"$flounder\n"
">_ commandline -ct\n"
"$fl\n"
">_ commandline -b # or just commandline\n"
"echo $flounder >&2 | less; and echo $catfish\n"
">_ commandline -p\n"
"echo $flounder >&2\n"
">_ commandline -j\n"
"echo $flounder >&2 | less"
msgstr ""
