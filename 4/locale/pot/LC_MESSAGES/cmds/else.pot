#: ../../../cmds/else.rst:2
msgid "else - execute command if a condition is not met"
msgstr ""

#: ../../../cmds/else.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/else.rst:7
msgid "if CONDITION; COMMANDS_TRUE ...; [else; COMMANDS_FALSE ...;] end"
msgstr ""

#: ../../../cmds/else.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/else.rst:14
msgid ""
":doc:`if <if>` will execute the command *CONDITION**. If the condition's "
"exit status is 0, the commands *COMMANDS_TRUE* will execute. If it is not 0 "
"and **else** is given, *COMMANDS_FALSE* will be executed."
msgstr ""

#: ../../../cmds/else.rst:20
msgid "Example"
msgstr ""

#: ../../../cmds/else.rst:22
msgid ""
"The following code tests whether a file *foo.txt* exists as a regular file."
msgstr ""

#: ../../../cmds/else.rst:26
msgid ""
"if test -f foo.txt\n"
"    echo foo.txt exists\n"
"else\n"
"    echo foo.txt does not exist\n"
"end"
msgstr ""
