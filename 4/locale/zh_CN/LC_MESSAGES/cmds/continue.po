#: ../../../cmds/continue.rst:2
msgid ""
"continue - skip the remainder of the current iteration of the current inner "
"loop"
msgstr ""

#: ../../../cmds/continue.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/continue.rst:7
msgid "LOOP_CONSTRUCT; [COMMANDS ...;] continue; [COMMANDS ...;] end"
msgstr ""

#: ../../../cmds/continue.rst:12
msgid "Description"
msgstr ""

#: ../../../cmds/continue.rst:14
msgid ""
"``continue`` skips the remainder of the current iteration of the current "
"inner loop, such as a :doc:`for <for>` loop or a :doc:`while <while>` loop. "
"It is usually added inside of a conditional block such as an :doc:`if <if>` "
"statement or a :doc:`switch <switch>` statement."
msgstr ""

#: ../../../cmds/continue.rst:16
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/continue.rst:19
msgid "Example"
msgstr ""

#: ../../../cmds/continue.rst:21
msgid ""
"The following code removes all tmp files that do not contain the word smurf."
msgstr ""

#: ../../../cmds/continue.rst:25
msgid ""
"for i in *.tmp\n"
"    if grep smurf $i\n"
"        continue\n"
"    end\n"
"    # This \"rm\" is skipped over if \"continue\" is executed.\n"
"    rm $i\n"
"    # As is this \"echo\"\n"
"    echo $i\n"
"end"
msgstr ""

#: ../../../cmds/continue.rst:36
msgid "See Also"
msgstr ""

#: ../../../cmds/continue.rst:38
msgid "the :doc:`break <break>` command, to stop the current inner loop"
msgstr ""
