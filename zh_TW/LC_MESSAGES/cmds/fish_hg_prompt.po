#: ../../../cmds/fish_hg_prompt.rst:4
msgid "fish_hg_prompt - output Mercurial information for use in a prompt"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:7
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/fish_hg_prompt.rst:9
msgid "fish_hg_prompt"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:15
msgid ""
"function fish_prompt\n"
"     printf '%s' $PWD (fish_hg_prompt) ' $ '\n"
"end"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:20
msgid "Description"
msgstr "描述"

#: ../../../cmds/fish_hg_prompt.rst:22
msgid ""
"The fish_hg_prompt function displays information about the current Mercurial "
"repository, if any."
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:24
msgid ""
"`Mercurial <https://www.mercurial-scm.org/>`_ (``hg``) must be installed."
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:26
msgid ""
"By default, only the current branch is shown because ``hg status`` can be "
"slow on a large repository. You can enable a more informative prompt by "
"setting the variable ``$fish_prompt_hg_show_informative_status``, for "
"example::"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:28
msgid "set --universal fish_prompt_hg_show_informative_status"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:30
msgid ""
"If you enabled the informative status, there are numerous customization "
"options, which can be controlled with fish variables."
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:32
msgid ""
"``$fish_color_hg_clean``, ``$fish_color_hg_modified`` and "
"``$fish_color_hg_dirty`` are colors used when the repository has the "
"respective status."
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:34
msgid "Some colors for status symbols:"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:36
msgid "``$fish_color_hg_added``"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:37
msgid "``$fish_color_hg_renamed``"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:38
msgid "``$fish_color_hg_copied``"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:39
msgid "``$fish_color_hg_deleted``"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:40
msgid "``$fish_color_hg_untracked``"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:41
msgid "``$fish_color_hg_unmerged``"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:43
msgid "The status symbols themselves:"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:45
msgid "``$fish_prompt_hg_status_added``, default '✚'"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:46
msgid "``$fish_prompt_hg_status_modified``, default '*'"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:47
msgid "``$fish_prompt_hg_status_copied``, default '⇒'"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:48
msgid "``$fish_prompt_hg_status_deleted``, default '✖'"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:49
msgid "``$fish_prompt_hg_status_untracked``, default '?'"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:50
msgid "``$fish_prompt_hg_status_unmerged``, default '!'"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:52
msgid ""
"Finally, ``$fish_prompt_hg_status_order``, which can be used to change the "
"order the status symbols appear in. It defaults to ``added modified copied "
"deleted untracked unmerged``."
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:54
msgid ""
"See also :doc:`fish_vcs_prompt <fish_vcs_prompt>`, which will call all "
"supported version control prompt functions, including git, Mercurial and "
"Subversion."
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:57
msgid "Example"
msgstr "範例"

#: ../../../cmds/fish_hg_prompt.rst:59
msgid "A simple prompt that displays hg info::"
msgstr ""

#: ../../../cmds/fish_hg_prompt.rst:61
msgid ""
"function fish_prompt\n"
"    ...\n"
"    set -g fish_prompt_hg_show_informative_status\n"
"    printf '%s %s$' $PWD (fish_hg_prompt)\n"
"end"
msgstr ""
