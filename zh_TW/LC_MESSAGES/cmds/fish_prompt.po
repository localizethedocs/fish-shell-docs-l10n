#: ../../../cmds/fish_prompt.rst:19
msgid "Description"
msgstr "描述"

#: ../../../cmds/fish_prompt.rst:21
msgid ""
"The ``fish_prompt`` function is executed when the prompt is to be shown, and "
"the output is used as a prompt."
msgstr ""

#: ../../../cmds/fish_prompt.rst:23
msgid ""
"The exit status of commands within ``fish_prompt`` will not modify the value "
"of :ref:`$status <variables-status>` outside of the ``fish_prompt`` function."
msgstr ""

#: ../../../cmds/fish_prompt.rst:25
msgid ""
"If :envvar:`fish_transient_prompt` is set to 1, ``fish_prompt --final-"
"rendering`` is run before executing the commandline."
msgstr ""

#: ../../../cmds/fish_prompt.rst:27
msgid ""
"If :envvar:`SHELL_PROMPT_PREFIX` or :envvar:`SHELL_PROMPT_SUFFIX` are set, "
"they are automatically prepended and appended to the left prompt. This "
"applies to all prompts regardless of whether ``fish_prompt`` has been "
"customized."
msgstr ""

#: ../../../cmds/fish_prompt.rst:29
msgid ""
"``fish`` ships with a number of example prompts that can be chosen with the "
"``fish_config`` command."
msgstr ""

#: ../../../cmds/fish_prompt.rst:33
msgid "Example"
msgstr "範例"

#: ../../../cmds/fish_prompt.rst:35
msgid "A simple prompt:"
msgstr ""

#: ../../../cmds/fish_prompt.rst:41
msgid ""
"function fish_prompt -d \"Write out the prompt\"\n"
"    # This shows up as USER@HOST /home/user/ >, with the directory colored\n"
"    # $USER and $hostname are set by fish, so you can just use them\n"
"    # instead of using `whoami` and `hostname`\n"
"    printf '%s@%s %s%s%s > ' $USER $hostname \\\n"
"        (set_color $fish_color_cwd) (prompt_pwd) (set_color --reset)\n"
"end"
msgstr ""
