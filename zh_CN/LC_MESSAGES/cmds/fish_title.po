#: ../../../cmds/fish_title.rst:4
msgid "fish_title - define the terminal's title"
msgstr ""

#: ../../../cmds/fish_title.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/fish_title.rst:9
msgid "fish_title"
msgstr ""

#: ../../../cmds/fish_title.rst:15
msgid ""
"function fish_title\n"
"    ...\n"
"end"
msgstr ""

#: ../../../cmds/fish_title.rst:21
msgid "Description"
msgstr ""

#: ../../../cmds/fish_title.rst:23
msgid ""
"The ``fish_title`` function is executed before and after a new command is "
"executed or put into the foreground and the output is used as a titlebar "
"message."
msgstr ""

#: ../../../cmds/fish_title.rst:25
msgid ""
"The first argument to fish_title contains the most recently executed "
"foreground command as a string, if any."
msgstr ""

#: ../../../cmds/fish_title.rst:27
msgid ""
"This requires that your terminal supports programmable titles and the "
"feature is turned on."
msgstr ""

#: ../../../cmds/fish_title.rst:31
msgid "Example"
msgstr ""

#: ../../../cmds/fish_title.rst:33
msgid "A simple title:"
msgstr ""

#: ../../../cmds/fish_title.rst:39
msgid ""
"function fish_title\n"
"    set -q argv[1]; or set argv fish\n"
"    # Looks like ~/d/fish: git log\n"
"    # or /e/apt: fish\n"
"    echo (fish_prompt_pwd_dir_length=1 prompt_pwd): $argv;\n"
"end"
msgstr ""
