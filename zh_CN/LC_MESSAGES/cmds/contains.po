#: ../../../cmds/contains.rst:4
msgid "contains - test if a word is present in a list"
msgstr ""

#: ../../../cmds/contains.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/contains.rst:9
msgid "contains [OPTIONS] KEY [VALUES ...]"
msgstr ""

#: ../../../cmds/contains.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/contains.rst:16
msgid ""
"``contains`` tests whether the set *VALUES* contains the string *KEY*. If "
"so, ``contains`` exits with code 0; if not, it exits with code 1."
msgstr ""

#: ../../../cmds/contains.rst:19
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/contains.rst:21
msgid "**-i** or **--index**"
msgstr ""

#: ../../../cmds/contains.rst:22
msgid ""
"Print the index (number of the element in the set) of the first matching "
"element."
msgstr ""

#: ../../../cmds/contains.rst:24
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/contains.rst:25
msgid "Displays help about using this command."
msgstr ""

#: ../../../cmds/contains.rst:27
msgid ""
"Note that ``contains`` interprets all arguments starting with a **-** as an "
"option to ``contains``, until an **--** argument is reached."
msgstr ""

#: ../../../cmds/contains.rst:29
msgid "See the examples below."
msgstr ""

#: ../../../cmds/contains.rst:32
msgid "Example"
msgstr ""

#: ../../../cmds/contains.rst:34
msgid ""
"If *animals* is a list of animals, the following will test if *animals* "
"contains \"cat\":"
msgstr ""

#: ../../../cmds/contains.rst:38
msgid ""
"if contains cat $animals\n"
"   echo Your animal list is evil!\n"
"end"
msgstr ""

#: ../../../cmds/contains.rst:43
msgid ""
"This code will add some directories to :envvar:`PATH` if they aren't yet "
"included:"
msgstr ""

#: ../../../cmds/contains.rst:47
msgid ""
"for i in ~/bin /usr/local/bin\n"
"    if not contains $i $PATH\n"
"        set PATH $PATH $i\n"
"    end\n"
"end"
msgstr ""

#: ../../../cmds/contains.rst:54
msgid ""
"While this will check if function ``hasargs`` is being ran with the **-q** "
"option:"
msgstr ""

#: ../../../cmds/contains.rst:58
msgid ""
"function hasargs\n"
"    if contains -- -q $argv\n"
"        echo '$argv contains a -q option'\n"
"    end\n"
"end"
msgstr ""

#: ../../../cmds/contains.rst:65
msgid ""
"The **--** here stops ``contains`` from treating **-q** to an option to "
"itself. Instead it treats it as a normal string to check."
msgstr ""
