#: ../../../cmds/end.rst:4
msgid "end - end a block of commands"
msgstr ""

#: ../../../cmds/end.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/end.rst:9
msgid ""
"begin\n"
"    [COMMANDS ...]\n"
"end"
msgstr ""

#: ../../../cmds/end.rst:15
msgid ""
"function NAME [OPTIONS]; COMMANDS ...; end\n"
"if CONDITION; COMMANDS_TRUE ...; [else; COMMANDS_FALSE ...;] end\n"
"switch VALUE; [case [WILDCARD ...]; [COMMANDS ...]; ...] end\n"
"while CONDITION; COMMANDS ...; end\n"
"for VARNAME in [VALUES ...]; COMMANDS ...; end"
msgstr ""

#: ../../../cmds/end.rst:24
msgid "Description"
msgstr ""

#: ../../../cmds/end.rst:26
msgid ""
"The **end** keyword ends a block of commands started by one of the following "
"commands:"
msgstr ""

#: ../../../cmds/end.rst:28
msgid ":doc:`begin <begin>` to start a block of commands"
msgstr ""

#: ../../../cmds/end.rst:29
msgid ":doc:`function <function>` to define a function"
msgstr ""

#: ../../../cmds/end.rst:30
msgid ""
":doc:`if <if>`, :doc:`switch <switch>` to conditionally execute commands"
msgstr ""

#: ../../../cmds/end.rst:31
msgid ""
":doc:`while <while>`, :doc:`for <for>` to perform commands multiple times"
msgstr ""

#: ../../../cmds/end.rst:33
msgid ""
"The **end** keyword does not change the current exit status. Instead, the "
"status after it will be the status returned by the most recent command."
msgstr ""
