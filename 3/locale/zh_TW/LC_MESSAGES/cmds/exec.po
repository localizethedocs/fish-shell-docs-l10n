#: ../../../cmds/exec.rst:4
msgid "exec - execute command in current process"
msgstr ""

#: ../../../cmds/exec.rst:7
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/exec.rst:9
msgid "exec COMMAND"
msgstr ""

#: ../../../cmds/exec.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/exec.rst:16
msgid ""
"``exec`` replaces the currently running shell with a new command. On "
"successful completion, ``exec`` never returns. ``exec`` cannot be used "
"inside a pipeline."
msgstr ""

#: ../../../cmds/exec.rst:18
msgid "The **--help** or **-h** option displays help about using this command."
msgstr ""

#: ../../../cmds/exec.rst:21
msgid "Example"
msgstr "範例"

#: ../../../cmds/exec.rst:23
msgid ""
"``exec emacs`` starts up the emacs text editor, and exits ``fish``. When "
"emacs exits, the session will terminate."
msgstr ""
