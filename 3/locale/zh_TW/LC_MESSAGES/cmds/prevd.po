#: ../../../cmds/prevd.rst:4
msgid "prevd - move backward through directory history"
msgstr ""

#: ../../../cmds/prevd.rst:7
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/prevd.rst:9
msgid "prevd [-l | --list] [POS]"
msgstr ""

#: ../../../cmds/prevd.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/prevd.rst:16
msgid ""
"``prevd`` moves backwards *POS* positions in the :ref:`history of visited "
"directories <directory-history>`; if the beginning of the history has been "
"hit, a warning is printed."
msgstr ""

#: ../../../cmds/prevd.rst:18
msgid ""
"If the **-l** or **--list** flag is specified, the current history is also "
"displayed."
msgstr ""

#: ../../../cmds/prevd.rst:20
msgid ""
"Note that the ``cd`` command limits directory history to the 25 most "
"recently visited directories. The history is stored in the :envvar:`dirprev` "
"and :envvar:`dirnext` variables which this command manipulates."
msgstr ""

#: ../../../cmds/prevd.rst:22
msgid "The **-h** or **--help** option displays help about using this command."
msgstr ""

#: ../../../cmds/prevd.rst:25
msgid "Example"
msgstr "範例"

#: ../../../cmds/prevd.rst:29
msgid ""
"cd /usr/src\n"
"# Working directory is now /usr/src\n"
"\n"
"cd /usr/src/fish-shell\n"
"# Working directory is now /usr/src/fish-shell\n"
"\n"
"prevd\n"
"# Working directory is now /usr/src\n"
"\n"
"nextd\n"
"# Working directory is now /usr/src/fish-shell"
msgstr ""

#: ../../../cmds/prevd.rst:42
msgid "See Also"
msgstr "另請參見"

#: ../../../cmds/prevd.rst:44
msgid ""
"the :doc:`cdh <cdh>` command to display a prompt to quickly navigate the "
"history"
msgstr ""

#: ../../../cmds/prevd.rst:45
msgid "the :doc:`dirh <dirh>` command to print the directory history"
msgstr ""

#: ../../../cmds/prevd.rst:46
msgid "the :doc:`nextd <nextd>` command to move forward"
msgstr ""
