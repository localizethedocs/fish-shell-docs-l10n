#: ../../../cmds/echo.rst:4
msgid "echo - display a line of text"
msgstr ""

#: ../../../cmds/echo.rst:7
msgid "Synopsis"
msgstr "概要"

#: ../../../cmds/echo.rst:9
msgid "echo [OPTIONS] [STRING]"
msgstr ""

#: ../../../cmds/echo.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/echo.rst:16
msgid "``echo`` displays *STRING* of text."
msgstr ""

#: ../../../cmds/echo.rst:18
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/echo.rst:20
msgid "**-n**"
msgstr ""

#: ../../../cmds/echo.rst:21
msgid "Do not output a newline."
msgstr ""

#: ../../../cmds/echo.rst:23
msgid "**-s**"
msgstr ""

#: ../../../cmds/echo.rst:24
msgid "Do not separate arguments with spaces."
msgstr ""

#: ../../../cmds/echo.rst:26
msgid "**-E**"
msgstr ""

#: ../../../cmds/echo.rst:27
msgid "Disable interpretation of backslash escapes (default)."
msgstr ""

#: ../../../cmds/echo.rst:29
msgid "**-e**"
msgstr ""

#: ../../../cmds/echo.rst:30
msgid "Enable interpretation of backslash escapes."
msgstr ""

#: ../../../cmds/echo.rst:32
msgid ""
"Unlike other shells, this echo accepts ``--`` to signal the end of the "
"options."
msgstr ""

#: ../../../cmds/echo.rst:35
msgid "Escape Sequences"
msgstr ""

#: ../../../cmds/echo.rst:37
msgid "If ``-e`` is used, the following sequences are recognized:"
msgstr ""

#: ../../../cmds/echo.rst:39
msgid "``\\`` backslash"
msgstr ""

#: ../../../cmds/echo.rst:41
msgid "``\\a`` alert (BEL)"
msgstr ""

#: ../../../cmds/echo.rst:43
msgid "``\\b`` backspace"
msgstr ""

#: ../../../cmds/echo.rst:45
msgid "``\\c`` produce no further output"
msgstr ""

#: ../../../cmds/echo.rst:47
msgid "``\\e`` escape"
msgstr ""

#: ../../../cmds/echo.rst:49
msgid "``\\f`` form feed"
msgstr ""

#: ../../../cmds/echo.rst:51
msgid "``\\n`` new line"
msgstr ""

#: ../../../cmds/echo.rst:53
msgid "``\\r`` carriage return"
msgstr ""

#: ../../../cmds/echo.rst:55
msgid "``\\t`` horizontal tab"
msgstr ""

#: ../../../cmds/echo.rst:57
msgid "``\\v`` vertical tab"
msgstr ""

#: ../../../cmds/echo.rst:59
msgid "``\\0NNN`` byte with octal value NNN (1 to 3 digits)"
msgstr ""

#: ../../../cmds/echo.rst:61
msgid "``\\xHH`` byte with hexadecimal value HH (1 to 2 digits)"
msgstr ""

#: ../../../cmds/echo.rst:64
msgid "Example"
msgstr "範例"

#: ../../../cmds/echo.rst:68
msgid ""
"> echo 'Hello World'\n"
"Hello World\n"
"\n"
"> echo -e 'Top\\nBottom'\n"
"Top\n"
"Bottom\n"
"\n"
"> echo -- -n\n"
"-n"
msgstr ""

#: ../../../cmds/echo.rst:79
msgid "See Also"
msgstr "另請參見"

#: ../../../cmds/echo.rst:81
msgid ""
"the :doc:`printf <printf>` command, for more control over output formatting"
msgstr ""
