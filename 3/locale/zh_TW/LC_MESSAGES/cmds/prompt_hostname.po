#: ../../../cmds/prompt_hostname.rst:4
msgid "prompt_hostname - print the hostname, shortened for use in the prompt"
msgstr ""

#: ../../../cmds/prompt_hostname.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/prompt_hostname.rst:9
msgid "prompt_hostname"
msgstr ""

#: ../../../cmds/prompt_hostname.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/prompt_hostname.rst:16
msgid ""
"``prompt_hostname`` prints a shortened version the current hostname for use "
"in the prompt. It will print just the first component of the hostname, "
"everything up to the first dot."
msgstr ""

#: ../../../cmds/prompt_hostname.rst:19
msgid "Examples"
msgstr ""

#: ../../../cmds/prompt_hostname.rst:23
msgid ""
"function fish_prompt\n"
"    echo -n (whoami)@(prompt_hostname) (prompt_pwd) '$ '\n"
"end"
msgstr ""

#: ../../../cmds/prompt_hostname.rst:29
msgid ""
"# The machine's full hostname is foo.bar.com\n"
">_ prompt_hostname\n"
"foo"
msgstr ""
