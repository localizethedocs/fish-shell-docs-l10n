#: ../../../cmds/builtin.rst:4
msgid "builtin - run a builtin command"
msgstr ""

#: ../../../cmds/builtin.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/builtin.rst:9
msgid ""
"builtin [OPTIONS] BUILTINNAME\n"
"builtin --query BUILTINNAME ...\n"
"builtin --names"
msgstr ""

#: ../../../cmds/builtin.rst:16
msgid "Description"
msgstr ""

#: ../../../cmds/builtin.rst:18
msgid ""
"``builtin`` forces the shell to use a builtin command named *BUILTIN*, "
"rather than a function or external program."
msgstr ""

#: ../../../cmds/builtin.rst:20
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/builtin.rst:22
msgid "**-n** or **--names**"
msgstr ""

#: ../../../cmds/builtin.rst:23
msgid "Lists the names of all defined builtins."
msgstr ""

#: ../../../cmds/builtin.rst:25
msgid "**-q** or **--query** *BUILTIN*"
msgstr ""

#: ../../../cmds/builtin.rst:26
msgid ""
"Tests if any of the specified builtins exist. If any exist, it returns 0, 1 "
"otherwise."
msgstr ""

#: ../../../cmds/builtin.rst:28
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/builtin.rst:29
msgid "Displays help about using this command."
msgstr ""

#: ../../../cmds/builtin.rst:32
msgid "Example"
msgstr ""

#: ../../../cmds/builtin.rst:36
msgid ""
"builtin jobs\n"
"# executes the jobs builtin, even if a function named jobs exists"
msgstr ""
