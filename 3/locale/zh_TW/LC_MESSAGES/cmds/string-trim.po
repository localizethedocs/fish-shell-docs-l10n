#: ../../../cmds/string-trim.rst:2
msgid "string-trim - remove trailing whitespace"
msgstr ""

#: ../../../cmds/string-trim.rst:5
msgid "Synopsis"
msgstr ""

#: ../../../cmds/string-trim.rst:9
msgid ""
"string trim [-l | --left] [-r | --right] [(-c | --chars) CHARS]\n"
"            [-q | --quiet] [STRING ...]"
msgstr ""

#: ../../../cmds/string-trim.rst:17
msgid "Description"
msgstr ""

#: ../../../cmds/string-trim.rst:21
msgid ""
"``string trim`` removes leading and trailing whitespace from each *STRING*. "
"If **-l** or **--left** is given, only leading whitespace is removed. If **-"
"r** or **--right** is given, only trailing whitespace is trimmed. The **-c** "
"or **--chars** switch causes the characters in *CHARS* to be removed instead "
"of whitespace. Exit status: 0 if at least one character was trimmed, or 1 "
"otherwise."
msgstr ""

#: ../../../cmds/string-trim.rst:26
msgid "Examples"
msgstr ""

#: ../../../cmds/string-trim.rst:32
msgid ""
">_ string trim ' abc  '\n"
"abc\n"
"\n"
">_ string trim --right --chars=yz xyzzy zany\n"
"x\n"
"zan"
msgstr ""
