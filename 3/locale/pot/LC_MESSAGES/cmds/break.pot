#: ../../../cmds/break.rst:4
msgid "break - stop the current inner loop"
msgstr ""

#: ../../../cmds/break.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/break.rst:9
msgid ""
"LOOP_CONSTRUCT\n"
"   [COMMANDS ...]\n"
"   break\n"
"   [COMMANDS ...]\n"
"end"
msgstr ""

#: ../../../cmds/break.rst:18
msgid "Description"
msgstr ""

#: ../../../cmds/break.rst:20
msgid ""
"``break`` halts a currently running loop (*LOOP_CONSTRUCT*), such as a :doc:"
"`for <for>` or :doc:`while <while>` loop. It is usually added inside of a "
"conditional block such as an :doc:`if <if>` block."
msgstr ""

#: ../../../cmds/break.rst:22
msgid "There are no parameters for ``break``."
msgstr ""

#: ../../../cmds/break.rst:25
msgid "Example"
msgstr ""

#: ../../../cmds/break.rst:26
msgid ""
"The following code searches all .c files for \"smurf\", and halts at the "
"first occurrence."
msgstr ""

#: ../../../cmds/break.rst:30
msgid ""
"for i in *.c\n"
"    if grep smurf $i\n"
"        echo Smurfs are present in $i\n"
"        break\n"
"    end\n"
"end"
msgstr ""

#: ../../../cmds/break.rst:38
msgid "See Also"
msgstr ""

#: ../../../cmds/break.rst:40
msgid ""
"the :doc:`continue <continue>` command, to skip the remainder of the current "
"iteration of the current inner loop"
msgstr ""
