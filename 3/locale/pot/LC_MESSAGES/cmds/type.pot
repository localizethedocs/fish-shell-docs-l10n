#: ../../../cmds/type.rst:4
msgid "type - locate a command and describe its type"
msgstr ""

#: ../../../cmds/type.rst:7
msgid "Synopsis"
msgstr ""

#: ../../../cmds/type.rst:9
msgid "type [OPTIONS] NAME [...]"
msgstr ""

#: ../../../cmds/type.rst:14
msgid "Description"
msgstr ""

#: ../../../cmds/type.rst:16
msgid ""
"With no options, :command:`type` indicates how each *NAME* would be "
"interpreted if used as a command name."
msgstr ""

#: ../../../cmds/type.rst:18
msgid "The following options are available:"
msgstr ""

#: ../../../cmds/type.rst:20
msgid "**-a** or **--all**"
msgstr ""

#: ../../../cmds/type.rst:21
msgid "Prints all of possible definitions of the specified names."
msgstr ""

#: ../../../cmds/type.rst:23
msgid "**-s** or **--short**"
msgstr ""

#: ../../../cmds/type.rst:24
msgid ""
"Suppresses function expansion when used with no options or with **-a**/**--"
"all**."
msgstr ""

#: ../../../cmds/type.rst:26
msgid "**-f** or **--no-functions**"
msgstr ""

#: ../../../cmds/type.rst:27
msgid "Suppresses function and builtin lookup."
msgstr ""

#: ../../../cmds/type.rst:29
msgid "**-t** or **--type**"
msgstr ""

#: ../../../cmds/type.rst:30
msgid ""
"Prints ``function``, ``builtin``, or ``file`` if *NAME* is a shell function, "
"builtin, or disk file, respectively."
msgstr ""

#: ../../../cmds/type.rst:32
msgid "**-p** or **--path**"
msgstr ""

#: ../../../cmds/type.rst:33
msgid ""
"Prints the path to *NAME* if *NAME* resolves to an executable file in :"
"envvar:`PATH`, the path to the script containing the definition of the "
"function *NAME* if *NAME* resolves to a function loaded from a file on disk "
"(i.e. not interactively defined at the prompt), or nothing otherwise."
msgstr ""

#: ../../../cmds/type.rst:35
msgid "**-P** or **--force-path**"
msgstr ""

#: ../../../cmds/type.rst:36
msgid ""
"Returns the path to the executable file *NAME*, presuming *NAME* is found in "
"the :envvar:`PATH` environment variable, or nothing otherwise. **--force-"
"path** explicitly resolves only the path to executable files in  :envvar:"
"`PATH`, regardless of whether *NAME* is shadowed by a function or builtin "
"with the same name."
msgstr ""

#: ../../../cmds/type.rst:38
msgid "**-q** or **--query**"
msgstr ""

#: ../../../cmds/type.rst:39
msgid ""
"Suppresses all output; this is useful when testing the exit status. For "
"compatibility with old fish versions this is also **--quiet**."
msgstr ""

#: ../../../cmds/type.rst:41
msgid "**-h** or **--help**"
msgstr ""

#: ../../../cmds/type.rst:42
msgid "Displays help about using this command."
msgstr ""

#: ../../../cmds/type.rst:44
msgid ""
"The **-q**, **-p**, **-t** and **-P** flags (and their long flag aliases) "
"are mutually exclusive. Only one can be specified at a time."
msgstr ""

#: ../../../cmds/type.rst:46
msgid ""
"``type`` returns 0 if at least one entry was found, 1 otherwise, and 2 for "
"invalid options or option combinations."
msgstr ""

#: ../../../cmds/type.rst:49
msgid "Example"
msgstr ""

#: ../../../cmds/type.rst:53
msgid ""
">_ type fg\n"
"fg is a builtin"
msgstr ""
